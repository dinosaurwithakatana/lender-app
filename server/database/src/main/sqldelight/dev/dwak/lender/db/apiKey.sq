CREATE TABLE dbApiKey (
    apiKey TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL UNIQUE
);

getByKey:
SELECT *
FROM dbApiKey
WHERE apiKey = ?
LIMIT 1;

hasKey:
SELECT EXISTS (
    SELECT *
    FROM dbApiKey
    WHERE apiKey = ?
);

insertKey:
INSERT INTO dbApiKey(apiKey, name)
VALUES ?;

getByName:
SELECT *
FROM dbApiKey
WHERE name = ?
LIMIT 1;

delete:
DELETE FROM dbApiKey
WHERE apiKey = ?;