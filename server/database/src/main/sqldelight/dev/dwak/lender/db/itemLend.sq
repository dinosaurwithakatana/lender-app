import dev.dwak.lender.db.DbLendStatus;
import kotlin.time.Instant;

CREATE TABLE dbItemLend (
    lend_id TEXT AS VALUE NOT NULL PRIMARY KEY,
    item_id TEXT NOT NULL,
    group_id TEXT,
    from_profile_id TEXT NOT NULL,
    to_profile_id TEXT NOT NULL,
    lend_created TEXT AS Instant NOT NULL DEFAULT CURRENT_TIMESTAMP,
    lend_updated TEXT AS Instant NOT NULL DEFAULT CURRENT_TIMESTAMP,
    lend_status TEXT AS DbLendStatus NOT NULL,
    quantity INTEGER NOT NULL DEFAULT 1,
    FOREIGN KEY (item_id) REFERENCES dbItem(id) ON DELETE CASCADE,
    FOREIGN KEY (group_id) REFERENCES dbGroup(id) ON DELETE CASCADE,
    FOREIGN KEY (from_profile_id) REFERENCES dbProfile(id) ON DELETE CASCADE,
    FOREIGN KEY (to_profile_id) REFERENCES dbProfile(id) ON DELETE CASCADE
);

insertLendRequestWithQuantity:
INSERT INTO dbItemLend(
    lend_id,
    item_id,
    group_id,
    from_profile_id,
    to_profile_id,
    quantity,
    lend_created,
    lend_updated,
    lend_status
)
SELECT
    :lend_id,
    :item_id,
    :group_id,
    :from_profile_id,
    :to_profile_id,
    :quantity,
    :lend_created,
    :lend_updated,
    'REQUESTED'
WHERE (
    SELECT i.total_quantity - COALESCE(SUM(il.quantity), 0)
    FROM dbItem i
    LEFT JOIN dbItemLend il ON i.id = il.item_id
        AND il.lend_status IN ('APPROVED', 'LENT')
    WHERE i.id = :item_id
    GROUP BY i.id, i.total_quantity
) >= :quantity;

getAvailableQuantity:
SELECT
    i.id,
    i.name,
    i.total_quantity,
    i.total_quantity - COALESCE(SUM(il.quantity), 0) AS available_quantity,
    COALESCE(SUM(il.quantity), 0) AS lent_quantity
FROM dbItem i
LEFT JOIN dbItemLend il ON i.id = il.item_id
    AND il.lend_status IN ('APPROVED', 'LENT')
WHERE i.id = :item_id
GROUP BY i.id, i.name, i.total_quantity;

listItemsWithAvailability:
SELECT
    i.id,
    i.name,
    i.description,
    i.total_quantity,
    i.total_quantity - COALESCE(SUM(il.quantity), 0) AS available_quantity,
    CASE
        WHEN i.total_quantity - COALESCE(SUM(il.quantity), 0) > 0 THEN 1
        ELSE 0
    END AS is_available
FROM dbItem i
LEFT JOIN dbItemLend il ON i.id = il.item_id
    AND il.lend_status IN ('APPROVED', 'LENT')
WHERE i.owned_by_profile_id = :owner_profile_id
GROUP BY i.id, i.name, i.description, i.total_quantity
ORDER BY i.name;

canLendQuantity:
SELECT
    (i.total_quantity - COALESCE(SUM(il.quantity), 0)) >= :requested_quantity AS can_lend
FROM dbItem i
LEFT JOIN dbItemLend il ON i.id = il.item_id
    AND il.lend_status IN ('APPROVED', 'LENT')
WHERE i.id = :item_id
GROUP BY i.id, i.total_quantity;

updateLendQuantity:
UPDATE dbItemLend
SET quantity = :quantity,
    lend_updated = :lend_updated
WHERE lend_id = :lend_id
AND lend_status = 'REQUESTED';

getQuantityBreakdown:
SELECT
    il.lend_id,
    il.to_profile_id,
    p.first_name,
    p.last_name,
    il.quantity,
    il.lend_status,
    il.lend_created
FROM dbItemLend il
JOIN dbProfile p ON il.to_profile_id = p.id
WHERE il.item_id = :item_id
AND il.lend_status IN ('APPROVED', 'LENT')
ORDER BY il.lend_created DESC;

approveLendRequestWithCheck:
UPDATE dbItemLend
SET lend_status = 'APPROVED',
    lend_updated = :lend_updated
WHERE lend_id = :lend_id
AND lend_status = 'REQUESTED'
AND quantity <= (
    SELECT i.total_quantity - COALESCE(SUM(il.quantity), 0)
    FROM dbItem i
    LEFT JOIN dbItemLend il ON i.id = il.item_id
        AND il.lend_status IN ('APPROVED', 'LENT')
        AND il.lend_id != :lend_id  -- Exclude current request
    WHERE i.id = (SELECT item_id FROM dbItemLend WHERE lend_id = :lend_id)
    GROUP BY i.id, i.total_quantity
);

createGuestProfileAndLend {
INSERT INTO dbProfile(id, user_id, first_name, last_name)
VALUES (:profile_id, NULL, :first_name, :last_name);

INSERT INTO dbItemLend(lend_id, item_id, group_id, from_profile_id, to_profile_id, quantity, lend_created, lend_updated, lend_status)
VALUES (:lend_id, :item_id, NULL, :from_profile_id, :profile_id, :quantity, :lend_created, :lend_created, 'REQUESTED');
}