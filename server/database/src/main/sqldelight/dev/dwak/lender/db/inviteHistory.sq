CREATE TABLE dbInviteHistory (
    invited_by_profile_id TEXT NOT NULL,
    invited_profile_id TEXT NOT NULL,
    PRIMARY KEY (invited_by_profile_id, invited_profile_id),
    FOREIGN KEY (invited_profile_id) REFERENCES dbProfile(id),
    FOREIGN KEY (invited_profile_id) REFERENCES dbProfile(id)
);

