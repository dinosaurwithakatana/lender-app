import dev.dwak.lender.db.DbRoleType;

CREATE TABLE dbRoles (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT AS DbRoleType NOT NULL UNIQUE
);

INSERT INTO dbRoles (name) VALUES ("ADMIN");
INSERT INTO dbRoles (name) VALUES ("USER");
INSERT INTO dbRoles (name) VALUES ("GUEST");

selectAllRoles:
SELECT * FROM dbRoles;

getByName:
SELECT * FROM dbRoles
WHERE name = ?;
