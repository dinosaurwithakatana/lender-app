CREATE TABLE dbProfile (
    id TEXT AS VALUE NOT NULL PRIMARY KEY,
    user_id TEXT NOT NULL UNIQUE,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    FOREIGN KEY (user_id) REFERENCES dbUser(id) ON DELETE CASCADE
);

CREATE INDEX idx_profiles_user_id ON dbProfile(user_id);

insert:
INSERT INTO dbProfile(id, user_id, first_name, last_name)
VALUES ?;

createUserWithProfile {
INSERT INTO dbUser(id, email, password)
VALUES (:user_id, :email, :password);

INSERT INTO dbUserRoles(user_id, role_id)
SELECT :user_id, id
FROM dbRoles
WHERE name = "USER";

INSERT INTO dbProfile(id, user_id, first_name, last_name)
VALUES (:profile_id, :user_id, :first_name, :last_name);

INSERT INTO dbInviteHistory(invited_by_profile_id, invited_profile_id)
SELECT created_by_profile_id, :profile_id
FROM dbInviteLink
WHERE link_token = :invite_token;
}

createAdminUserWithProfile {
INSERT INTO dbUser(id, email, password)
VALUES (:user_id, :email, :password);

INSERT INTO dbUserRoles(user_id, role_id)
SELECT :user_id, id
FROM dbRoles
WHERE name = "ADMIN";

INSERT INTO dbProfile(id, user_id, first_name, last_name)
VALUES (:profile_id, :user_id, :first_name, :last_name);
}

findByEmail:
SELECT p.*
FROM dbProfile p
JOIN dbUser u ON p.user_id = u.id
WHERE u.email = ?;