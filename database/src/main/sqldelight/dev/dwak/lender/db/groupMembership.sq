import dev.dwak.lender.db.DbGroupMembershipStatus;
import kotlin.time.Instant;

CREATE TABLE dbGroupMembership (
    id TEXT AS VALUE NOT NULL PRIMARY KEY,
    profile_id TEXT NOT NULL,
    group_id TEXT NOT NULL,
    status TEXT AS DbGroupMembershipStatus NOT NULL,
    created_at TEXT AS Instant NOT NULL,
    FOREIGN KEY (profile_id) REFERENCES dbProfile(id) ON DELETE CASCADE,
    FOREIGN KEY (group_id) REFERENCES dbGroup(id) ON DELETE CASCADE
);

insert:
INSERT INTO dbGroupMembership(id, profile_id, group_id, created_at, status)
VALUES ?;

isOwnerForGroup:
SELECT EXISTS (
    SELECT 1 FROM dbGroupMembership
    WHERE profile_id = ?
    AND group_id = ?
    AND status = 'OWNER'
) AS is_owner;

getMembershipStatus:
SELECT status FROM dbGroupMembership
WHERE profile_id = :profile_id
AND group_id = :group_id;

isMemberOfGroup:
SELECT EXISTS (
    SELECT 1 FROM dbGroupMembership
    WHERE profile_id = :profile_id
    AND group_id = :group_id
    AND status != 'REQUESTED'
) AS is_member;

getGroupsWhereOwner:
SELECT g.*
FROM dbGroup g
JOIN dbGroupMembership gm ON g.id = gm.group_id
WHERE gm.profile_id = :profile_id
AND gm.status = 'OWNER';

removeMember:
DELETE FROM dbGroupMembership
WHERE profile_id = ?
AND status != 'OWNER';

groupsForProfile:
SELECT g.*
FROM dbGroup g
JOIN dbGroupMembership gm ON g.id = gm.group_id
WHERE gm.profile_id = :profile_id
AND status != 'REQUESTED';

profilesInGroup:
SELECT
    p.*
FROM dbGroupMembership gm
JOIN dbProfile p ON gm.profile_id = p.id
WHERE gm.group_id = :group_id
AND status != 'REQUESTED';