import kotlin.time.Instant;

CREATE TABLE dbItem (
    id TEXT AS VALUE NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    owned_by_profile_id TEXT NOT NULL,
    created_at TEXT AS Instant NOT NULL,
    description TEXT,
    total_quantity INTEGER NOT NULL DEFAULT 1,
    FOREIGN KEY (owned_by_profile_id) REFERENCES dbProfile(id)
);

insert:
INSERT INTO dbItem(id, name, owned_by_profile_id, created_at, description, total_quantity)
VALUES ?;

delete:
DELETE FROM dbItem
WHERE id = ?;

itemOwnedBy:
SELECT EXISTS(
    SELECT 1 FROM dbItem
    WHERE id = :item_id
    AND owned_by_profile_id = :profile_id
) AS is_owner;

itemExists:
SELECT EXISTS(
SELECT 1 FROM dbItem
WHERE id = :item_id
);

itemsForProfile:
SELECT * FROM dbItem
WHERE owned_by_profile_id = ?;