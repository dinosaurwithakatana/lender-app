import kotlin.time.Instant;

CREATE TABLE dbGroup (
    id TEXT AS VALUE NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    created_at TEXT AS Instant NOT NULL
);

insert:
INSERT INTO dbGroup(id, name, created_at)
VALUES ?;

createGroupAndAddCreator {
    INSERT INTO dbGroup(id, name, created_at)
    VALUES (:group_id, :group_name, :created_at);

    INSERT INTO dbGroupMembership(id, profile_id, group_id, status, created_at)
    VALUES(:membership_id, :profile_id, :group_id, :created_at, "OWNER");
}

selectAll:
SELECT * FROM dbGroup;