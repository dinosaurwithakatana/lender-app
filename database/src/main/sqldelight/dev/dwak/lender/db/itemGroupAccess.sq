import kotlin.time.Instant;

CREATE TABLE dbItemGroupAccess (
    item_id TEXT NOT NULL,
    group_id TEXT NOT NULL,
    granted_at TEXT AS Instant NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (item_id, group_id),
    FOREIGN KEY (item_id) REFERENCES dbItem(id) ON DELETE CASCADE,
    FOREIGN KEY (group_id) REFERENCES dbGroup(id) ON DELETE CASCADE
);

CREATE INDEX idx_item_group_access_group ON dbItemGroupAccess(group_id);
CREATE INDEX idx_item_group_access_item ON dbItemGroupAccess(item_id);


insert:
INSERT INTO dbItemGroupAccess(item_id, group_id, granted_at)
VALUES ?;

removeItemFromGroup:
DELETE FROM dbItemGroupAccess
WHERE item_id = :item_id
AND group_id = :group_id;

removeItemFromAllGroups:
DELETE FROM dbItemGroupAccess
WHERE item_id = :item_id;

getGroupsForItem:
SELECT
    g.*,
    iga.granted_at
FROM dbItemGroupAccess iga
JOIN dbGroup g ON iga.group_id = g.id
WHERE iga.item_id = :item_id
ORDER BY g.name;

getItemsForGroup:
SELECT
    i.*,
    iga.granted_at,
    p.first_name AS owner_first_name,
    p.last_name AS owner_last_name
FROM dbItemGroupAccess iga
JOIN dbItem i ON iga.item_id = i.id
JOIN dbProfile p ON i.owned_by_profile_id = p.id
WHERE iga.group_id = :group_id
ORDER BY i.name;